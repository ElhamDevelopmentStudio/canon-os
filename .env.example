# CanonOS root environment example
# Copy to .env for local development and keep real secrets out of Git.

# Shared runtime
CANONOS_ENV=local
CANONOS_LOG_LEVEL=info

# Frontend
VITE_APP_NAME=CanonOS
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_DOCKER_API_BASE_URL=/api
VITE_ENABLE_DEV_TOOLS=true
FRONTEND_HOST_PORT=5173

# Django backend
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-local-development-secret
DJANGO_DEBUG=true
DJANGO_LOG_LEVEL=INFO
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api,frontend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
API_HOST_PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_HOST_PORT=15432
POSTGRES_DB=canonos
POSTGRES_USER=canonos
POSTGRES_PASSWORD=canonos
DATABASE_URL=postgresql://canonos:canonos@localhost:15432/canonos

# Redis
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_HOST_PORT=16379
REDIS_DB=0
CELERY_RESULT_DB=1
REDIS_URL=redis://localhost:16379/0

# Celery
CELERY_BROKER_URL=redis://localhost:16379/0
CELERY_RESULT_BACKEND=redis://localhost:16379/1
CELERY_TASK_ALWAYS_EAGER=false

# Backups and user exports
BACKUP_STORAGE_PATH=./tmp/backups

# Optional provider configuration, disabled until provider adapters are implemented
AI_PROVIDER=disabled
AI_PROVIDER_API_KEY=
METADATA_PROVIDER=manual
METADATA_PROVIDER_API_KEY=

# MiniMax chat intake and AI-assisted discovery.
# Module chats use MiniMax for conversation understanding. Media Archaeologist
# also uses MiniMax for AI-generated discovery when this key is configured.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT_SECONDS=20

# Live web context for AI-assisted Media Archaeologist discovery.
CANONOS_WEB_SEARCH_ENABLED=true
CANONOS_WEB_SEARCH_TIMEOUT_SECONDS=8
CANONOS_WEB_SEARCH_MAX_CHARS=5000

# Provider configuration

# TMDB
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# OMDB
OMDB_API_KEY=

# Google Books
GOOGLE_BOOKS_API_KEY=

# Set to false in deterministic test environments. Local development uses provider
# network calls by default when DJANGO_SETTINGS_MODULE is not config.settings.test.
CANONOS_METADATA_ENABLE_NETWORK=

# Optional OAuth/account imports

# Trakt
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=

# AniList
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=

# CanonOS provider token encryption key
CANONOS_PROVIDER_TOKEN_ENCRYPTION_KEY=
